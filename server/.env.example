# ── Mailtrap (Email Testing Sandbox) ─────────────────────────────────────────
# Get these from: mailtrap.io → Your Inbox → Integration → Mailtrap API
MAILTRAP_API_TOKEN=your_token_here
MAILTRAP_INBOX_ID=your_inbox_id_here

# ── Sender identity ───────────────────────────────────────────────────────────
FROM_EMAIL=hello@summitvalleybank.com
FROM_NAME=Summit Valley Bank

# ── Server port ───────────────────────────────────────────────────────────────
PORT=3000
