# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address
# Free tier: use onboarding@resend.dev (sends only to your verified email)
# Production: use your verified domain e.g. notifications@summitvalleybank.com
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Summit Valley Bank

PORT=3000
